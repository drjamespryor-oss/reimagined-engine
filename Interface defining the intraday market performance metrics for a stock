// Example function to log stock performance
function logPerformance(data: Record<string, StockPerformance>): void {
  Object.values(data).forEach(stock => {
    const direction = stock.netChange >= 0 ? "📈" : "📉";
    const sign = stock.netChange >= 0 ? "+" : "";
    console.log(`${direction} ${stock.companyName} (${stock.ticker}): Currently at $${stock.currentPrice.toFixed(2)} (${sign}${stock.netChange.toFixed(2)} / ${sign}${stock.percentageChange.toFixed(2)}%)`);
  });
}

